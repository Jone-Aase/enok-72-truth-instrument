<Folder><name>Ekvator — gamle markører</name>
  <Placemark>
    <name>EKV-01: Catequilla</name>
    <description><![CDATA[<b>Type:</b> arkeologisk_observatorium<br/><b>Land:</b> Ecuador<br/><b>Lat:</b> 0.00000°<br/><b>Lon:</b> -78.42869°<br/><b>Alder:</b> ca. 1226 år<br/><b>Merknad:</b> Pre-columbiansk Quitu-Cara observatorium ca. 800 e.Kr. Wikipedia oppgir eksakt 0.00000°N.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Catequilla'>https://en.wikipedia.org/wiki/Catequilla</a>]]></description>
    <styleUrl>#style_Ekvator</styleUrl>
    <Point><coordinates>-78.42869,0.00000,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>EKV-02: Pyramid of Oyambaro</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_markor<br/><b>Land:</b> Ecuador<br/><b>Lat:</b> -0.16°<br/><b>Lon:</b> -78.32°<br/><b>Alder:</b> ca. 290 år<br/><b>Merknad:</b> French Geodesic Mission 1736 baseline-endepunkt. Original møllesteiner gjenfunnet av Humboldt 1802. Gjenoppbygget 1836 og 1936. Koordinater omtrentlige.<br/><b>Kilde:</b> <a href='http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html'>http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html</a>]]></description>
    <styleUrl>#style_Ekvator</styleUrl>
    <Point><coordinates>-78.32,-0.16,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>EKV-03: Pyramid of Caraburo</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_markor<br/><b>Land:</b> Ecuador<br/><b>Lat:</b> -0.13°<br/><b>Lon:</b> -78.36°<br/><b>Alder:</b> ca. 290 år<br/><b>Merknad:</b> French Geodesic Mission 1736 andre baseline-endepunkt. Koordinater omtrentlige.<br/><b>Kilde:</b> <a href='http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html'>http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html</a>]]></description>
    <styleUrl>#style_Ekvator</styleUrl>
    <Point><coordinates>-78.36,-0.13,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>EKV-04: Mitad del Mundo monument</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_markor<br/><b>Land:</b> Ecuador<br/><b>Lat:</b> -0.00222°<br/><b>Lon:</b> -78.45583°<br/><b>Alder:</b> ca. 90 år<br/><b>Merknad:</b> Bygget 1936 basert på 1736-måling. Plassert 247m sør for moderne ekvator.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Ciudad_Mitad_del_Mundo'>https://en.wikipedia.org/wiki/Ciudad_Mitad_del_Mundo</a>]]></description>
    <styleUrl>#style_Ekvator</styleUrl>
    <Point><coordinates>-78.45583,-0.00222,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>EKV-05: Pontianak Equator Monument</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_markor<br/><b>Land:</b> Indonesia<br/><b>Lat:</b> 0.001056°<br/><b>Lon:</b> 109.322222°<br/><b>Alder:</b> ca. 98 år<br/><b>Merknad:</b> Nederlandsk kolonitid 1928. 117m nord for moderne ekvator.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Equator_Monument'>https://en.wikipedia.org/wiki/Equator_Monument</a>]]></description>
    <styleUrl>#style_Ekvator</styleUrl>
    <Point><coordinates>109.322222,0.001056,0</coordinates></Point>
  </Placemark>
</Folder>
<Folder><name>Cancer — gamle markører</name>
  <Placemark>
    <name>CAN-01: Modhera Sun Temple</name>
    <description><![CDATA[<b>Type:</b> arkeologisk_tempel<br/><b>Land:</b> India<br/><b>Lat:</b> 23.583806°<br/><b>Lon:</b> 72.132686°<br/><b>Alder:</b> ca. 1000 år<br/><b>Merknad:</b> Solanki-dynastiet 1026 e.Kr. UNESCO. Astronomisk alignet til soloppgang ved jevndøgn.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Sun_Temple%2C_Modhera'>https://en.wikipedia.org/wiki/Sun_Temple%2C_Modhera</a>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>72.132686,23.583806,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>CAN-02: Dholavira</name>
    <description><![CDATA[<b>Type:</b> arkeologisk_by<br/><b>Land:</b> India<br/><b>Lat:</b> 23.888606°<br/><b>Lon:</b> 70.213636°<br/><b>Alder:</b> ca. 4900 år<br/><b>Merknad:</b> Harappan Indus Valley-by ca. 2650-1900 f.Kr. UNESCO.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Dholavira'>https://en.wikipedia.org/wiki/Dholavira</a>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>70.213636,23.888606,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>CAN-03: Chiayi Tropic of Cancer Monument</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_markor<br/><b>Land:</b> Taiwan<br/><b>Lat:</b> 23.453917°<br/><b>Lon:</b> 120.416722°<br/><b>Alder:</b> ca. 118 år<br/><b>Merknad:</b> Japansk kolonitid 1908. Pre-WGS84.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Tropic_of_Cancer_Monument'>https://en.wikipedia.org/wiki/Tropic_of_Cancer_Monument</a>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>120.416722,23.453917,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>CAN-04: Aswan/Syene (Eratosthenes)</name>
    <description><![CDATA[<b>Type:</b> arkeologisk_observasjon<br/><b>Land:</b> Egypt<br/><b>Lat:</b> 24.0880°<br/><b>Lon:</b> 32.8990°<br/><b>Alder:</b> ca. 2265 år<br/><b>Merknad:</b> Eratosthenes brukte 240 f.Kr. som nordlig referansepunkt. Brønn der solen ikke kastet skygge på sommersolverv.<br/><b>Kilde:</b> <a href='http://kiwihellenist.blogspot.com/2015/11/eratosthenes-and-well.html'>http://kiwihellenist.blogspot.com/2015/11/eratosthenes-and-well.html</a>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>32.8990,24.0880,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>CAN-05: Ujjain Jantar Mantar</name>
    <description><![CDATA[<b>Type:</b> vitenskapelig_observatorium<br/><b>Land:</b> India<br/><b>Lat:</b> 23.1824°<br/><b>Lon:</b> 75.7764°<br/><b>Alder:</b> ca. 300 år<br/><b>Merknad:</b> Sawai Jai Singh II 1719/1725. Surya Siddhanta-tradisjon plasserte Cancer her.<br/><b>Kilde:</b> <a href='https://en.wikipedia.org/wiki/Jantar_Mantar%2C_Ujjain'>https://en.wikipedia.org/wiki/Jantar_Mantar%2C_Ujjain</a>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>75.7764,23.1824,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>CAN-06: Mazatlán havn</name>
    <description><![CDATA[<b>Type:</b> historisk_havn<br/><b>Land:</b> Mexico<br/><b>Lat:</b> 23.217°<br/><b>Lon:</b> -106.42°<br/><b>Alder:</b> ca. 300 år<br/><b>Merknad:</b> Spansk koloni-havn. Manila-galleon-rute. Skipslogger fra 1700-tallet.<br/>]]></description>
    <styleUrl>#style_Cancer</styleUrl>
    <Point><coordinates>-106.42,23.217,0</coordinates></Point>
  </Placemark>
