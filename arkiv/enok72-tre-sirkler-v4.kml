    <Folder>
      <name>Astronomisk motiverte (5)</name>
      <Placemark>
        <name>EKV-01: Catequilla</name>
        <description><![CDATA[
          <p><b>Type:</b> arkeologisk_observatorium (astronomisk motivert)</p>
          <p><b>Land:</b> Ecuador | <b>Kontinent:</b> Sør-Amerika</p>
          <p><b>Alder:</b> ~1226 år</p>
          <p><b>Koordinater:</b> 0.00000, -78.42869</p>
          <p><b>Merknad:</b> Pre-columbiansk Quitu-Cara observatorium ca. 800 e.Kr. Wikipedia oppgir eksakt 0.00000°N.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Catequilla">https://en.wikipedia.org/wiki/Catequilla</a></p>
        ]]></description>
        <styleUrl>#ekv-astro</styleUrl>
        <Point><coordinates>-78.42869,0.00000,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>EKV-02: Pyramid of Oyambaro</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_markor (astronomisk motivert)</p>
          <p><b>Land:</b> Ecuador | <b>Kontinent:</b> Sør-Amerika</p>
          <p><b>Alder:</b> ~290 år</p>
          <p><b>Koordinater:</b> -0.16, -78.32</p>
          <p><b>Merknad:</b> French Geodesic Mission 1736 baseline-endepunkt. Original møllesteiner gjenfunnet av Humboldt 1802. Gjenoppbygget 1836 og 1936. Koordinater omtrentlige.</p>
          <p><b>Kilde:</b> <a href="http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html">http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html</a></p>
        ]]></description>
        <styleUrl>#ekv-astro</styleUrl>
        <Point><coordinates>-78.32,-0.16,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>EKV-03: Pyramid of Caraburo</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_markor (astronomisk motivert)</p>
          <p><b>Land:</b> Ecuador | <b>Kontinent:</b> Sør-Amerika</p>
          <p><b>Alder:</b> ~290 år</p>
          <p><b>Koordinater:</b> -0.13, -78.36</p>
          <p><b>Merknad:</b> French Geodesic Mission 1736 andre baseline-endepunkt. Koordinater omtrentlige.</p>
          <p><b>Kilde:</b> <a href="http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html">http://rodama1789.blogspot.com/2019/10/the-pyramids-of-yaruqui.html</a></p>
        ]]></description>
        <styleUrl>#ekv-astro</styleUrl>
        <Point><coordinates>-78.36,-0.13,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>EKV-04: Mitad del Mundo monument</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_markor (astronomisk motivert)</p>
          <p><b>Land:</b> Ecuador | <b>Kontinent:</b> Sør-Amerika</p>
          <p><b>Alder:</b> ~90 år</p>
          <p><b>Koordinater:</b> -0.00222, -78.45583</p>
          <p><b>Merknad:</b> Bygget 1936 basert på 1736-måling. Plassert 247m sør for moderne ekvator.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Ciudad_Mitad_del_Mundo">https://en.wikipedia.org/wiki/Ciudad_Mitad_del_Mundo</a></p>
        ]]></description>
        <styleUrl>#ekv-astro</styleUrl>
        <Point><coordinates>-78.45583,-0.00222,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>EKV-05: Pontianak Equator Monument</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_markor (astronomisk motivert)</p>
          <p><b>Land:</b> Indonesia | <b>Kontinent:</b> Asia</p>
          <p><b>Alder:</b> ~98 år</p>
          <p><b>Koordinater:</b> 0.001056, 109.322222</p>
          <p><b>Merknad:</b> Nederlandsk kolonitid 1928. 117m nord for moderne ekvator.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Equator_Monument">https://en.wikipedia.org/wiki/Equator_Monument</a></p>
        ]]></description>
        <styleUrl>#ekv-astro</styleUrl>
        <Point><coordinates>109.322222,0.001056,0</coordinates></Point>
      </Placemark>
