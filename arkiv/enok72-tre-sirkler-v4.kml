      </Placemark>
      <Placemark>
        <name>CAN-03: Chiayi Tropic of Cancer Monument</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_markor (astronomisk motivert)</p>
          <p><b>Land:</b> Taiwan | <b>Kontinent:</b> Asia</p>
          <p><b>Alder:</b> ~118 år</p>
          <p><b>Koordinater:</b> 23.453917, 120.416722</p>
          <p><b>Merknad:</b> Japansk kolonitid 1908. Pre-WGS84.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Tropic_of_Cancer_Monument">https://en.wikipedia.org/wiki/Tropic_of_Cancer_Monument</a></p>
        ]]></description>
        <styleUrl>#can-astro</styleUrl>
        <Point><coordinates>120.416722,23.453917,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>CAN-04: Aswan/Syene (Eratosthenes)</name>
        <description><![CDATA[
          <p><b>Type:</b> arkeologisk_observasjon (astronomisk motivert)</p>
          <p><b>Land:</b> Egypt | <b>Kontinent:</b> Afrika</p>
          <p><b>Alder:</b> ~2265 år</p>
          <p><b>Koordinater:</b> 24.0880, 32.8990</p>
          <p><b>Merknad:</b> Eratosthenes brukte 240 f.Kr. som nordlig referansepunkt. Brønn der solen ikke kastet skygge på sommersolverv.</p>
          <p><b>Kilde:</b> <a href="http://kiwihellenist.blogspot.com/2015/11/eratosthenes-and-well.html">http://kiwihellenist.blogspot.com/2015/11/eratosthenes-and-well.html</a></p>
        ]]></description>
        <styleUrl>#can-astro</styleUrl>
        <Point><coordinates>32.8990,24.0880,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>CAN-05: Ujjain Jantar Mantar</name>
        <description><![CDATA[
          <p><b>Type:</b> vitenskapelig_observatorium (astronomisk motivert)</p>
          <p><b>Land:</b> India | <b>Kontinent:</b> Asia</p>
          <p><b>Alder:</b> ~300 år</p>
          <p><b>Koordinater:</b> 23.1824, 75.7764</p>
          <p><b>Merknad:</b> Sawai Jai Singh II 1719/1725. Surya Siddhanta-tradisjon plasserte Cancer her.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Jantar_Mantar%2C_Ujjain">https://en.wikipedia.org/wiki/Jantar_Mantar%2C_Ujjain</a></p>
        ]]></description>
        <styleUrl>#can-astro</styleUrl>
        <Point><coordinates>75.7764,23.1824,0</coordinates></Point>
      </Placemark>
