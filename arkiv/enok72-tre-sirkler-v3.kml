      <Placemark>
        <name>CAN-01: Modhera Sun Temple</name>
        <description><![CDATA[
          <p><b>Type:</b> arkeologisk_tempel (astronomisk motivert)</p>
          <p><b>Land:</b> India | <b>Kontinent:</b> Asia</p>
          <p><b>Alder:</b> ~1000 år</p>
          <p><b>Koordinater:</b> 23.583806, 72.132686</p>
          <p><b>Merknad:</b> Solanki-dynastiet 1026 e.Kr. UNESCO. Astronomisk alignet til soloppgang ved jevndøgn.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Sun_Temple%2C_Modhera">https://en.wikipedia.org/wiki/Sun_Temple%2C_Modhera</a></p>
        ]]></description>
        <styleUrl>#can-astro</styleUrl>
        <Point><coordinates>72.132686,23.583806,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>CAN-02: Dholavira</name>
        <description><![CDATA[
          <p><b>Type:</b> arkeologisk_by (astronomisk motivert)</p>
          <p><b>Land:</b> India | <b>Kontinent:</b> Asia</p>
          <p><b>Alder:</b> ~4900 år</p>
          <p><b>Koordinater:</b> 23.888606, 70.213636</p>
          <p><b>Merknad:</b> Harappan Indus Valley-by ca. 2650-1900 f.Kr. UNESCO.</p>
          <p><b>Kilde:</b> <a href="https://en.wikipedia.org/wiki/Dholavira">https://en.wikipedia.org/wiki/Dholavira</a></p>
        ]]></description>
